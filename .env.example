# ===== App =====
APP_NAME=JadeAI

# ===== Auth =====
AUTH_ENABLED=true
REGISTRATION_MODE=closed
SESSION_TTL_DAYS=30

# Enable only when a trusted reverse proxy strips client-supplied forwarding
# headers and writes its own X-Forwarded-For / X-Real-IP values.
TRUST_PROXY_HEADERS=false

# Legacy fingerprint mode is development-only and disabled in production.
ENABLE_FINGERPRINT_AUTH=false

# ===== Database =====
DB_TYPE=sqlite

# PostgreSQL (when DB_TYPE=postgresql)
DATABASE_URL=postgresql://user:password@localhost:5432/jadeai

# SQLite (when DB_TYPE=sqlite)
SQLITE_PATH=./data/jade.db

# Explicit development fixture only. Never enable this in production.
SEED_DEMO_DATA=false

# ===== Per-user LLM secrets =====
# Generate each 32-byte key with: openssl rand -base64 32
# Keep old versions during rotation so existing profiles remain decryptable.
LLM_ENCRYPTION_KEYS={"1":"replace-with-base64-32-byte-key"}
LLM_ENCRYPTION_ACTIVE_KEY_VERSION=1

# Provider request timeout in milliseconds. Values are clamped to 1s-5m.
LLM_REQUEST_TIMEOUT_MS=60000

# Comma-separated exact origins and/or CIDRs approved by the operator for
# self-hosted models. Leave empty to allow only public HTTPS endpoints.
# Example: http://127.0.0.1:11434,10.30.0.0/16
LLM_BASE_URL_ALLOWLIST=

# ===== GitHub App read-only repository sync =====
# Create a GitHub App with read-only Metadata and Contents permissions.
# Setup URL:   https://your-jadeai.example/api/github/callback
# Webhook URL: https://your-jadeai.example/api/github/webhooks
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# Use escaped newlines when the deployment platform only supports one-line values.
GITHUB_APP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nreplace-with-github-app-private-key\n-----END PRIVATE KEY-----
GITHUB_WEBHOOK_SECRET=

# Optional GitHub Enterprise Server endpoints. Public GitHub defaults are used
# when these values are omitted.
# GITHUB_API_BASE_URL=https://api.github.com
# GITHUB_WEB_BASE_URL=https://github.com

# Optional limits for one cron reconciliation pass (1-500, default 100).
GITHUB_RECONCILE_REPOSITORY_LIMIT=100
GITHUB_RECONCILE_JOB_LIMIT=100

# ===== i18n =====
DEFAULT_LOCALE=zh
